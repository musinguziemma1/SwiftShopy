# NextAuth
NEXTAUTH_SECRET=swiftshopy-secret-key-change-in-production-32chars
NEXTAUTH_URL=http://localhost:3014

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# MTN MoMo API (Collections)
# Get these from https://momodeveloper.mtn.com/
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_COLLECTIONS_PRIMARY_KEY=your_collections_primary_key
MTN_API_USER_ID=your_api_user_uuid
MTN_API_KEY=your_api_key
MTN_ENVIRONMENT=sandbox
MTN_CALLBACK_URL=https://your-domain.com/api/webhooks/mtn
MTN_WEBHOOK_SECRET=your_optional_webhook_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3014
NEXT_PUBLIC_APP_NAME=SwiftShopy
